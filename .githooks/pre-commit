#!/bin/sh
# pre-commit hook:
#   1. Auf Feature-Branches: hebt EINMAL PRO BRANCH die Version automatisch an
#      (scripts/bump_version.py) und nimmt die 6 Versions-Dateien in den Commit.
#   2. Danach (und auf main): pr√ºft, dass alle Versions-Dateien konsistent sind.
#
# So bleibt die im Login-Fenster angezeigte Version/Changelog-Liste automatisch
# aktuell ‚Äì ohne direkten Push auf das gesch√ºtzte main.
#
# Einrichten (einmalig): git config core.hooksPath .githooks
# Bump ausnahmsweise √ºberspringen: git commit --no-verify

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ROOT=$(git rev-parse --show-toplevel)
BRANCH=$(git rev-parse --abbrev-ref HEAD)

get_pkg_version() {  # $1 = Datei-Inhalt-Quelle (cat oder git show)
  grep '"version"' 2>/dev/null | sed 's/.*"version": *"\([^"]*\)".*/\1/'
}

# ‚îÄ‚îÄ 1. Auto-Version-Bump (nur Feature-Branches, einmal pro Branch) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
if [ "$BRANCH" != "main" ] && [ "$BRANCH" != "HEAD" ]; then
  CUR=$(cat "$ROOT/frontend/package.json" | get_pkg_version)
  BASE=$(git show origin/main:frontend/package.json 2>/dev/null | get_pkg_version)
  [ -z "$BASE" ] && BASE=$(git show main:frontend/package.json 2>/dev/null | get_pkg_version)

  # Nur bumpen, wenn dieser Branch die Version noch NICHT angehoben hat
  # (Arbeitskopie == Basis auf main). Danach: CUR > BASE -> kein weiterer Bump.
  if [ -n "$CUR" ] && [ "$CUR" = "$BASE" ]; then
    if command -v python3 >/dev/null 2>&1; then
      echo ""
      echo "  ${YELLOW}[Auto-Version]${NC} Hebe Version an (einmal pro Branch) ‚Ä¶"
      if python3 "$ROOT/scripts/bump_version.py"; then
        git add "$ROOT/frontend/package.json" \
                "$ROOT/backend/app/core/config.py" \
                "$ROOT/docker-compose.yml" \
                "$ROOT/docker-compose.local.yml" \
                "$ROOT/frontend/src/data/changelog.js" \
                "$ROOT/CHANGELOG.md"
      else
        echo "  ${RED}Auto-Version fehlgeschlagen${NC} ‚Äî Commit l√§uft ohne Bump weiter."
      fi
    else
      echo "  ${YELLOW}[Auto-Version]${NC} python3 nicht gefunden ‚Äî Bump √ºbersprungen."
    fi
  fi
fi

# ‚îÄ‚îÄ 2. Konsistenz-Check (immer, wenn Versions-Dateien im Commit sind) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
STAGED=$(git diff --cached --name-only)
RELEVANT=$(echo "$STAGED" | grep -E "frontend/package.json|backend/app/core/config.py|docker-compose.yml|docker-compose.local.yml|frontend/src/data/changelog.js|CHANGELOG.md")

if [ -z "$RELEVANT" ]; then
  exit 0
fi

PKG_VERSION=$(grep '"version"' "$ROOT/frontend/package.json" | sed 's/.*"version": *"\([^"]*\)".*/\1/')
CFG_VERSION=$(grep 'APP_VERSION.*str.*=' "$ROOT/backend/app/core/config.py" | sed 's/.*"\([^"]*\)".*/\1/')
DC_VERSION=$(grep 'APP_VERSION:.*:-' "$ROOT/docker-compose.yml" | sed 's/.*:-\([^}]*\)}.*/\1/')
CL_VERSION=$(grep "version:" "$ROOT/frontend/src/data/changelog.js" | head -1 | sed "s/.*'\([^']*\)'.*/\1/")

echo ""
echo "  ${YELLOW}[Version-Check]${NC}"
printf "  %-45s %s\n" "frontend/package.json"           "$PKG_VERSION"
printf "  %-45s %s\n" "backend/app/core/config.py"      "$CFG_VERSION"
printf "  %-45s %s\n" "docker-compose.yml"              "$DC_VERSION"
printf "  %-45s %s\n" "frontend/src/data/changelog.js"  "$CL_VERSION"

FAIL=0

[ "$PKG_VERSION" != "$CFG_VERSION" ] && echo "  ${RED}‚úó package.json ($PKG_VERSION) ‚âÝ config.py ($CFG_VERSION)${NC}"      && FAIL=1
[ "$PKG_VERSION" != "$DC_VERSION"  ] && echo "  ${RED}‚úó package.json ($PKG_VERSION) ‚âÝ docker-compose.yml ($DC_VERSION)${NC}" && FAIL=1
[ "$PKG_VERSION" != "$CL_VERSION"  ] && echo "  ${RED}‚úó package.json ($PKG_VERSION) ‚âÝ changelog.js ($CL_VERSION)${NC}"      && FAIL=1

if [ $FAIL -eq 1 ]; then
  echo ""
  echo "  ${RED}Commit abgebrochen ‚Äî Versionen stimmen nicht √ºberein.${NC}"
  echo "  Tipp: python3 scripts/bump_version.py --title 'Beschreibung' ausf√ºhren."
  echo ""
  exit 1
fi

echo "  ${GREEN}‚úì Alle Versionen √ºbereinstimmend ($PKG_VERSION)${NC}"
echo ""
exit 0
