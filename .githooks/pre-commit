#!/bin/sh
# pre-commit hook: prüft ob alle Versions-Dateien dieselbe Version haben.
# Schlägt fehl und blockiert den Commit wenn Versionen auseinanderlaufen.
#
# Einrichten (einmalig): git config core.hooksPath .githooks

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ROOT=$(git rev-parse --show-toplevel)

# Nur prüfen wenn mindestens eine versions-relevante Datei im Staging ist
STAGED=$(git diff --cached --name-only)
RELEVANT=$(echo "$STAGED" | grep -E "frontend/package.json|backend/app/core/config.py|docker-compose.yml|docker-compose.local.yml|frontend/src/data/changelog.js|CHANGELOG.md")

if [ -z "$RELEVANT" ]; then
  exit 0
fi

# Versionen auslesen
PKG_VERSION=$(grep '"version"' "$ROOT/frontend/package.json" | sed 's/.*"version": *"\([^"]*\)".*/\1/')
CFG_VERSION=$(grep 'APP_VERSION.*str.*=' "$ROOT/backend/app/core/config.py" | sed 's/.*"\([^"]*\)".*/\1/')
DC_VERSION=$(grep 'APP_VERSION:.*:-' "$ROOT/docker-compose.yml" | sed 's/.*:-\([^}]*\)}.*/\1/')
CL_VERSION=$(grep "version:" "$ROOT/frontend/src/data/changelog.js" | head -1 | sed "s/.*'\([^']*\)'.*/\1/")

echo ""
echo "  ${YELLOW}[Version-Check]${NC}"
printf "  %-45s %s\n" "frontend/package.json"           "$PKG_VERSION"
printf "  %-45s %s\n" "backend/app/core/config.py"      "$CFG_VERSION"
printf "  %-45s %s\n" "docker-compose.yml"              "$DC_VERSION"
printf "  %-45s %s\n" "frontend/src/data/changelog.js"  "$CL_VERSION"

FAIL=0

[ "$PKG_VERSION" != "$CFG_VERSION" ] && echo "  ${RED}✗ package.json ($PKG_VERSION) ≠ config.py ($CFG_VERSION)${NC}"      && FAIL=1
[ "$PKG_VERSION" != "$DC_VERSION"  ] && echo "  ${RED}✗ package.json ($PKG_VERSION) ≠ docker-compose.yml ($DC_VERSION)${NC}" && FAIL=1
[ "$PKG_VERSION" != "$CL_VERSION"  ] && echo "  ${RED}✗ package.json ($PKG_VERSION) ≠ changelog.js ($CL_VERSION)${NC}"      && FAIL=1

if [ $FAIL -eq 1 ]; then
  echo ""
  echo "  ${RED}Commit abgebrochen — Versionen stimmen nicht überein.${NC}"
  echo "  Tipp: .\\bump-version.ps1 -Version X.Y.Z -Titel 'Beschreibung'"
  echo ""
  exit 1
fi

echo "  ${GREEN}✓ Alle Versionen übereinstimmend ($PKG_VERSION)${NC}"
echo ""
exit 0
