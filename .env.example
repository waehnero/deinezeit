# ============================================================
# DeineZeit – Konfigurationsvorlage
# Kopieren nach: .env
# ACHTUNG: .env niemals in Git committen!
# ============================================================

# ── Datenbank ────────────────────────────────────────────────
DB_USER=deinezeit
DB_PASSWORD=BITTE_AENDERN_sicheres_passwort_min_16_zeichen
DB_NAME=deinezeit

# ── Backend-Sicherheit ───────────────────────────────────────
# Zufälligen Schlüssel generieren:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BITTE_AENDERN_zufaelliger_schluessel_min_64_zeichen

# ── Domain & URLs ────────────────────────────────────────────
DOMAIN=deine-domain.at
FRONTEND_URL=https://deine-domain.at

# ── App-Modus ────────────────────────────────────────────────
# "production" → API-Docs deaktiviert, optimiert
# "development" → API-Docs unter /api/docs erreichbar
APP_ENV=production

# ── Backup-Sicherheit ────────────────────────────────────────
# Zufälligen Token generieren:
#   python3 -c "import secrets; print(secrets.token_hex(16))"
BACKUP_PING_TOKEN=BITTE_AENDERN_backup_token

# ── WebAuthn / Passkeys (optional) ──────────────────────────
WEBAUTHN_RP_ID=deine-domain.at
WEBAUTHN_RP_NAME=DeineZeit

# ── Datei-Speicher (MinIO) ───────────────────────────────────
# Zufällige Zugangsdaten generieren:
#   python3 -c "import secrets; print(secrets.token_hex(8))"
MINIO_ROOT_USER=BITTE_AENDERN_minio_user
MINIO_ROOT_PASSWORD=BITTE_AENDERN_minio_passwort_min_8_zeichen

# ── Let's Encrypt (SSL-Zertifikate) ─────────────────────────
ADMIN_EMAIL=admin@deine-domain.at
